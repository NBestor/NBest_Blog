FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=sqlite:///D:/0Study/xlab/study/project/backend/data/private-blog.db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=10080

# AI 配置（用于文章简介自动生成，DeepSeek API）
# 注册地址: https://platform.deepseek.com/api_keys
# AI_API_KEY 为空时 AI 功能自动禁用
AI_API_KEY=sk-your-deepseek-api-key
# API 端点，可切换其他 OpenAI 兼容的服务商
AI_BASE_URL=https://api.deepseek.com
# 模型名，支持 deepseek-chat / deepseek-reasoner 或其他兼容模型
AI_MODEL=deepseek-chat
