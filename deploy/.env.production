# ====================
# 生产环境变量配置
# ====================
# 复制此文件为 backend/.env，并修改对应的值

# 前端地址（填写你的服务器 IP 或域名，如 http://123.456.789.0）
FRONTEND_ORIGIN=http://YOUR_SERVER_IP

# 数据库（容器内路径，不要修改）
DATABASE_URL=sqlite:///app/data/private-blog.db

# JWT 密钥（务必改成一个长随机字符串！）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# JWT 过期时间（分钟），默认 7 天
JWT_EXPIRE_MINUTES=10080

# ====================
# AI 配置（DeepSeek API，可选）
# ====================
# 注册地址: https://platform.deepseek.com/api_keys
# 留空则 AI 功能自动禁用
AI_API_KEY=sk-your-deepseek-api-key

# API 端点，可切换其他 OpenAI 兼容的服务商
AI_BASE_URL=https://api.deepseek.com

# 模型名
AI_MODEL=deepseek-chat